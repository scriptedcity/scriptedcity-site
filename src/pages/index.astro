---
import Note from "@src/components/Note.astro";
import Layout from "@src/layouts/Layout.astro";
import Spotify from "@src/components/Spotify.astro";
import Tags from "@src/components/Tags.astro";
import { getCollection, render } from "astro:content";
import { getParams, sortFunction, getDateText } from "@src/utils/posts";

const content = await getCollection("top");
const announcement = content.find((c) => c.id.endsWith("announcement"));

const Announcement =
  announcement &&
  announcement.body != null &&
  (await render(announcement)).Content;

const about = content.find((c) => c.id.endsWith("about"));
const About = about && about.body != null && (await render(about)).Content;

const offer = content.find((c) => c.id.endsWith("offer"));
const Offer = offer && offer.body != null && (await render(offer)).Content;

const recentWorks = (
  await getCollection(
    "posts",
    (post) => getParams(post.filePath).category === "works",
  )
)
  .sort(sortFunction)
  .slice(0, 3);
---

<Layout title="Top">
  <article class="flex flex-col gap-4">
    <section class="flex flex-col gap-4">
      <div class="flex items-baseline">
        <h2
          class="font-display text-4xl sm:text-5xl text-primary tracking-wider"
        >
          Information
        </h2>
      </div>
      {
        Announcement && (
          <Note type="error">
            <div class="px-4 prose prose-sm md:prose-base">
              <Announcement />
            </div>
          </Note>
        )
      }
      {
        Offer && (
          <Note type="success">
            <div class="px-4 prose prose-sm md:prose-base">
              <Offer />
            </div>
          </Note>
        )
      }
      {
        About && (
          <Note type="info">
            <div class="px-4 prose prose-sm md:prose-base">
              <About />
            </div>
          </Note>
        )
      }
    </section>
    {
      recentWorks.length > 0 && (
        <section>
          <div class="flex items-baseline gap-3">
            <h2 class="font-display text-4xl sm:text-5xl text-primary tracking-wider">
              Recent Works
            </h2>
            <a
              href="/posts/works"
              class="font-condensed text-xs tracking-[0.15em] text-base-content/50 uppercase hover:text-primary transition-colors duration-200"
            >
              View All →
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {recentWorks.map((post) => {
              const { category, slug } = getParams(post.filePath);
              const url = `/posts/${category}/${slug}`;
              return (
                <a
                  href={url}
                  class="group relative overflow-hidden rounded-[var(--radius-box)] aspect-[4/5] block transition-shadow duration-500 hover:shadow-[0_0_28px_var(--color-primary)]"
                >
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-in-out group-hover:scale-[1.06]"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent" />
                  <div class="absolute bottom-0 left-0 right-0 p-4">
                    <time class="font-condensed text-xs tracking-[0.18em] mb-1 text-white/50 block">
                      {getDateText(post.data.date)}
                    </time>
                    <h3 class="font-display text-2xl text-white leading-tight mb-1">
                      {post.data.title}
                    </h3>
                    <div class="opacity-0 translate-y-1.5 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
                      {post.data.description && (
                        <p class="font-condensed text-xs text-white/65 mb-2">
                          {post.data.description}
                        </p>
                      )}
                      <Tags tags={post.data.tags} align="left" />
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )
    }
    <section>
      <div class="flex items-baseline gap-3">
        <h2
          class="font-display
        text-4xl
        sm:text-5xl
        text-primary
        tracking-wider"
        >
          Spotify
        </h2>
      </div>
      <Spotify />
    </section>
  </article>
</Layout>
