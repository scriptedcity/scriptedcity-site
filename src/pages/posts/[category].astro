---
import { getCollection } from "astro:content";
import { getParams, sortFunction } from "@src/utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const categories = [
    ...new Set(posts.map((post) => getParams(post.filePath).category)),
  ];
  return categories.map((category) => {
    return {
      params: {
        category,
      },
    };
  });
}

const { category } = Astro.params;

const posts = (
  await getCollection("posts", (post) => {
    return getParams(post.filePath).category === category;
  })
).sort(sortFunction);

import Layout from "@src/layouts/Layout.astro";
import { getDateText } from "@src/utils/posts";
import Tags from "@src/components/Tags.astro";
import { capitalize } from "@src/utils/utils";

const title = capitalize(category);
const featured = posts[0];
const rest = posts.slice(1);
---

<Layout title={title}>
  <div class="mb-8">
    <h1 class="font-display text-7xl sm:text-9xl leading-none text-primary tracking-wider">
      {title}
    </h1>
    <p class="font-condensed text-sm tracking-[0.2em] mt-1 text-base-content/50 uppercase">
      {posts.length} WORKS
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {featured && (() => {
      const { category: cat, slug } = getParams(featured.filePath);
      const url = `/posts/${cat}/${slug}`;
      return (
        <a
          href={url}
          class="group col-span-1 sm:col-span-2 relative overflow-hidden rounded-[var(--radius-box)] aspect-video block transition-shadow duration-500 hover:shadow-[0_0_36px_var(--color-primary)]"
        >
          <img
            src={featured.data.image}
            alt={featured.data.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-in-out group-hover:scale-[1.06]"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent" />
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <time class="font-condensed text-xs tracking-[0.18em] mb-1 text-white/55 block">
              {getDateText(featured.data.date)}
            </time>
            <h2 class="font-display text-3xl sm:text-4xl text-white leading-tight mb-1">
              {featured.data.title}
            </h2>
            <div class="opacity-0 translate-y-1.5 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
              {featured.data.description && (
                <p class="font-condensed text-sm text-white/70 mb-2">
                  {featured.data.description}
                </p>
              )}
              <Tags tags={featured.data.tags} align="left" />
            </div>
          </div>
        </a>
      );
    })()}

    {rest.map((post) => {
      const { category: cat, slug } = getParams(post.filePath);
      const url = `/posts/${cat}/${slug}`;
      return (
        <a
          href={url}
          class="group relative overflow-hidden rounded-[var(--radius-box)] aspect-[4/5] block transition-shadow duration-500 hover:shadow-[0_0_28px_var(--color-primary)]"
        >
          <img
            src={post.data.image}
            alt={post.data.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-in-out group-hover:scale-[1.06]"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent" />
          <div class="absolute bottom-0 left-0 right-0 p-4">
            <time class="font-condensed text-xs tracking-[0.18em] mb-1 text-white/50 block">
              {getDateText(post.data.date)}
            </time>
            <h2 class="font-display text-2xl text-white leading-tight mb-1">
              {post.data.title}
            </h2>
            <div class="opacity-0 translate-y-1.5 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
              {post.data.description && (
                <p class="font-condensed text-xs text-white/65 mb-2">
                  {post.data.description}
                </p>
              )}
              <Tags tags={post.data.tags} align="left" />
            </div>
          </div>
        </a>
      );
    })}
  </div>
</Layout>
